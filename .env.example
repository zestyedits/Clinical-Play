# Database (Supabase PostgreSQL or any PostgreSQL instance)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend)
RESEND_API_KEY=re_...

# Server
PORT=5000
NODE_ENV=development

# Optional: Your deployed site URL (for OG images, email links)
# SITE_URL=https://your-domain.com

# Optional: Founding member slots
FOUNDING_MEMBER_TOTAL_SLOTS=100
FOUNDING_MEMBER_REMAINING_SLOTS=100
